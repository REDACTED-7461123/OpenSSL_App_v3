<Window x:Class="OpenSSL_App_v3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenSSL GUI" Height="600" Width="980"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12" Background="{DynamicResource AppBgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="31"/>
            <RowDefinition Height="95"/>
        </Grid.RowDefinitions>

        <!-- Left menu -->
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="4" CornerRadius="10" BorderBrush="#333" BorderThickness="1" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Mode" FontSize="18" FontWeight="SemiBold" Margin="0 0 0 12"/>
                    <ListBox x:Name="ModeList" SelectionChanged="ModeList_SelectionChanged" SelectedIndex="0">
                        <ListBoxItem Content="🔐 Encrypt" />
                        <ListBoxItem Content="#️⃣ Hash" />
                        <ListBoxItem Content="🔑 Key generation" />
                        <ListBoxItem Content="🕘 History" />
                    </ListBox>

                    <Separator Margin="0 12 0 12"/>

                    <!-- <Button Content="Export history to CSV" Click="ExportHistoryCsv_Click" Margin="0 0 0 8"/>
                    <Button Content="Clear history" Click="ClearHistory_Click"/> -->

                    <Separator Margin="0 12 0 12"/>

                    <TextBlock Text="Status" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusText" Text="Ready" TextWrapping="Wrap" Margin="0 6 0 0"/>
                    <!-- <Button Content="Switch theme" Click="ToggleTheme_Click" Width="100" Margin="0 12 0 0"/> -->
                </StackPanel>

                <!-- Pinned to Grid.Row 1 -->
                <Button Grid.Row="1" ToolTip="Preferences" HorizontalAlignment="Left" Margin="0 12 0 0" 
                        Background="Transparent" BorderBrush="Transparent" Click="Settings_Tab"> 
                    <Image Source="/Assets/settings.png" Width="16" Height="16"/>
                </Button>
            </Grid>
        </Border>

        <!-- Main content container -->
        <Border Grid.Column="2" Grid.Row="0" CornerRadius="10" BorderBrush="#333" BorderThickness="1" Padding="12">
            <Grid>

                <!-- Encryption panel -->
                <Grid x:Name="PanelEncrypt">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Encrypt / Decrypt" FontSize="20" FontWeight="SemiBold" Margin="0 0 0 10"/>

                    <!-- File selection -->
                    <StackPanel Grid.Row="1" Margin="0 8 0 0">
                        <TextBlock Text="File" FontWeight="SemiBold"/>
                        <DockPanel Margin="0 6 0 0">
                            <TextBox x:Name="EncFilePathBox" Height="28" Width="465" Margin="0 0 0 0" VerticalContentAlignment="Center"/>
                            <Button Content="Browse" Width="90" Click="BrowseEncFile_Click"/>
                        </DockPanel>
                    </StackPanel>

                    <!-- Password + strength -->
                    <Grid Grid.Row="2" Margin="0 10 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Password" FontWeight="SemiBold"/>
                            <PasswordBox x:Name="PasswordBox" Height="28" PasswordChanged="PasswordBox_PasswordChanged"/>
                            <Button Content="Generate password" Width="160" Margin="0 6 0 0" Click="GeneratePassword_Click"/>
                            <CheckBox x:Name="AllowWeakPassword" Content="Allow weak password (not recommended)" Margin="0 6 0 0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Password strength" FontWeight="SemiBold"/>
                            <ProgressBar x:Name="PwdStrengthBar" Height="18" Minimum="0" Maximum="4" Value="0" Margin="0 6 0 0"/>
                            <TextBlock x:Name="PwdStrengthText" Text="—" Margin="0 6 0 0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Algorithm choice -->
                    <Grid Grid.Row="3" Margin="0 10 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Encryption algorithm" FontWeight="SemiBold"/>
                            <ComboBox x:Name="AlgoBox" Height="28" Margin="0 6 0 0" Background="{DynamicResource PanelBgBrush}" Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Advanced" FontWeight="SemiBold"/>
                            <CheckBox x:Name="UseSalt" Content="Use -salt (recommended)" IsChecked="True" Margin="0 6 0 0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Actions -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0 12 0 0">
                        <Button Content="Encrypt" Width="120" Margin="0 0 8 0" Click="Encrypt_Click"/>
                        <Button Content="Decrypt" Width="120" Margin="0 0 8 0" Click="Decrypt_Click"/>
                        <Button Content="Show command" Width="160" Click="ShowEncCommand_Click"/>
                    </StackPanel>

                    <TextBlock Grid.Row="5" Text="Operation result will appear in the log below." Foreground="#888" Margin="0 10 0 0"/>
                </Grid>

                <!-- Hash panel -->
                <Grid x:Name="PanelHash" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="File hashing" FontSize="20" FontWeight="SemiBold" Margin="0 0 0 10"/>

                    <!-- Submode selector -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 6 0 10">
                        <RadioButton x:Name="RbHashSingle" Content="Compute hash" IsChecked="True"
                     Margin="0 0 16 0" Checked="HashModeChanged"/>
                        <RadioButton x:Name="RbHashComparison" Content="Compare two files"
                     Checked="HashModeChanged"/>
                    </StackPanel>

                    <!-- File A -->
                    <StackPanel Grid.Row="2" Margin="0 6 0 0">
                        <TextBlock Text="File A" FontWeight="SemiBold"/>
                        <DockPanel Margin="0 6 0 0">
                            <TextBox x:Name="HashFilePathBox" Height="28" Width="465" Margin="0 0 8 0" VerticalContentAlignment="Center"/>
                            <Button Content="Browse" Width="90" Click="BrowseHashFile_Click"/>
                        </DockPanel>
                    </StackPanel>

                    <!-- File B (only for compare) -->
                    <StackPanel Grid.Row="3" x:Name="HashComparePanel" Visibility="Collapsed" Margin="0 10 0 0">
                        <TextBlock Text="File B" FontWeight="SemiBold"/>
                        <DockPanel Margin="0 6 0 0">
                            <TextBox x:Name="HashFilePathBoxB" Height="28" Width="465" Margin="0 0 8 0" VerticalContentAlignment="Center"/>
                            <Button Content="Browse" Width="90" Click="BrowseHashFileB_Click"/>
                        </DockPanel>
                    </StackPanel>

                    <!-- Algo + actions -->
                    <StackPanel Grid.Row="4" Margin="0 12 0 0">
                        <TextBlock Text="Hash algorithm" FontWeight="SemiBold"/>
                        <ComboBox x:Name="HashAlgoBox" Height="28" Margin="0 6 0 0"/>

                        <StackPanel Orientation="Horizontal" Margin="0 12 0 0">
                            <Button x:Name="BtnHashSingle" Content="Compute hash" Width="140" Margin="0 0 8 0" Click="Hash_Click"/>
                            <Button x:Name="BtnHashCompare" Content="Compare" Width="140" Margin="0 0 8 0" Click="CompareHash_Click" Visibility="Collapsed"/>
                            <Button Content="Show command" Width="160" Click="ShowHashCommand_Click"/>
                        </StackPanel>

                        <TextBlock x:Name="CompareResultText" Text="" Margin="0 12 0 0" FontWeight="SemiBold"/>
                        <TextBlock Text="Operation result will appear in the log below." Foreground="{DynamicResource MutedTextBrush}" Margin="0 6 0 0"/>
                    </StackPanel>
                </Grid>

                <!-- Keys panel -->
                <Grid x:Name="PanelKeys" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="RSA key generation" FontSize="20" FontWeight="SemiBold" Margin="0 0 0 10"/>

                    <StackPanel Grid.Row="1" Margin="0 8 0 0">
                        <TextBlock Text="Key length (bits)" FontWeight="SemiBold"/>
                        <ComboBox x:Name="RsaBitsBox" Height="28" SelectedIndex="0" Margin="0 6 0 0">
                            <ComboBoxItem Content="2048"/>
                            <ComboBoxItem Content="3072"/>
                            <ComboBoxItem Content="4096"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0 10 0 0">
                        <TextBlock Text="Output file" FontWeight="SemiBold"/>
                        <DockPanel Margin="0 6 0 0">
                            <TextBox x:Name="KeyOutPathBox" Height="28" Margin="0 0 8 0" VerticalContentAlignment="Center" Text="rsa_key.pem"/>
                            <Button Content="Choose" Width="90" Click="BrowseKeyOut_Click"/>
                        </DockPanel>

                        <StackPanel Orientation="Horizontal" Margin="0 12 0 0">
                            <Button Content="Generate" Width="140" Margin="0 0 8 0" Click="GenRsa_Click"/>
                            <Button Content="Show command" Width="160" Click="ShowKeyCommand_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Row="3" Text="Operation result will appear in the log below." Foreground="#888" Margin="0 10 0 0"/>
                </Grid>

                <!-- History panel -->
                <Grid x:Name="PanelHistory" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Operation history" FontSize="20" FontWeight="SemiBold" Margin="0 0 0 10"/>

                    <DataGrid Grid.Row="1" x:Name="HistoryGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="170"/>
                            <DataGridTextColumn Header="Operation" Binding="{Binding Operation}" Width="120"/>
                            <DataGridTextColumn Header="Input" Binding="{Binding InputPath}" Width="*"/>
                            <DataGridTextColumn Header="Output" Binding="{Binding OutputPath}" Width="*"/>
                            <DataGridTextColumn Header="Alg." Binding="{Binding Algorithm}" Width="120"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Settings panel -->
                <Grid x:Name="PanelSettings"  Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Margin="0 0 0 10"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

 
                            <!-- Security -->
                            <Border CornerRadius="10" BorderBrush="#333" BorderThickness="1" Padding="12" Background="{DynamicResource PanelBgBrush}" Margin="0 0 0 10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Security" FontWeight="SemiBold" FontSize="14" Margin="0 0 0 10"/>

                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                        <CheckBox x:Name="ClearPasswordAfterOpCheck" Content="Clear password box after Encrypt/Decrypt" IsChecked="True"/>
                                        <CheckBox x:Name="PreventClipboardCheck" Content="Do not auto-copy hashes/keys to clipboard" IsChecked="True" Margin="0 6 0 0"/>
                                        <CheckBox x:Name="ConfirmDangerousOpsCheck" Content="Confirm risky actions (weak password / DES / MD5)" IsChecked="True" Margin="0 6 0 0"/>
                                    </StackPanel>


                                    <Separator Grid.Row="2" Grid.ColumnSpan="3" Margin="0 12 0 12"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Password plugins" FontWeight="SemiBold"/>
                                    <Grid Grid.Row="4" Grid.ColumnSpan="3" Margin="0 6 0 0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="220"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Strength checker" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" x:Name="PasswordCheckerCombo" Height="28" SelectionChanged="PasswordCheckerCombo_SelectionChanged"/>
                                    </Grid>

                                    <TextBlock Grid.Row="5" Grid.ColumnSpan="3" x:Name="PluginSummaryText" Margin="0 10 0 0" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                            
                            <!-- App / Paths -->
                            <Border CornerRadius="10" BorderBrush="#333" BorderThickness="1" Padding="12" Background="{DynamicResource PanelBgBrush}" Margin="0 0 0 10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="App and plugins" FontWeight="SemiBold" FontSize="14" Margin="0 0 0 10"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Theme" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="ThemeCombo" Height="28"/>
                                </Grid>
                            </Border>

                            <!-- Defaults -->
                            <Border CornerRadius="10" BorderBrush="#333" BorderThickness="1" Padding="12" Background="{DynamicResource PanelBgBrush}" Margin="0 0 0 10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="4" Text="Defaults" FontWeight="SemiBold" FontSize="14" Margin="0 0 0 10"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Default encryption algorithm" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="DefaultEncAlgoBox" Height="28"/>

                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Default hash" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0 -50 0 0"/>
                                    <ComboBox Grid.Row="1" Grid.Column="3" x:Name="DefaultHashAlgoBox" Height="28" Margin="0 0 0 0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Default RSA bits" VerticalAlignment="Center" Margin="0 10 0 0"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="DefaultRsaBitsBox" Height="28" SelectedIndex="0" Margin="0 10 0 0">
                                        <ComboBoxItem Content="2048"/>
                                        <ComboBoxItem Content="3072"/>
                                        <ComboBoxItem Content="4096"/>
                                    </ComboBox>

                                    <CheckBox Grid.Row="2" Grid.Column="3" x:Name="DefaultSaltCheck" Content="Use -salt by default" IsChecked="True" Margin="0 10 0 0"/>
                                </Grid>
                            </Border>

                            <!-- History & privacy -->
                            <Border CornerRadius="10" BorderBrush="#333" BorderThickness="1" Padding="12" Background="{DynamicResource PanelBgBrush}" Margin="0 0 0 10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Historynprivacy" FontWeight="SemiBold" FontSize="14" Margin="0 0 0 10"/>

                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                        <CheckBox x:Name="HistoryEnabledCheck" Content="Enable history logging" IsChecked="True"/>
                                        <CheckBox x:Name="LogOnlyFileNamesCheck" Content="Log only file names (no full paths)" IsChecked="True" Margin="0 6 0 0"/>
                                        <CheckBox x:Name="NeverLogPasswordsCheck" Content="Never store passwords (recommended)" IsChecked="True" Margin="0 6 0 0"/>
                                        <TextBlock Text="Tip: even hashing or encrypting a path can leak info. Prefer short logs." Foreground="{DynamicResource MutedTextBrush}" Margin="22 6 0 0" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2">
                                        <TextBlock Text="History retention" FontWeight="SemiBold"/>
                                        <ComboBox x:Name="HistoryRetentionBox" Height="28" SelectedIndex="1" Margin="0 6 0 0">
                                            <ComboBoxItem Content="Keep forever"/>
                                            <ComboBoxItem Content="30 days"/>
                                            <ComboBoxItem Content="90 days"/>
                                            <ComboBoxItem Content="180 days"/>
                                        </ComboBox>

                                        <StackPanel Orientation="Horizontal" Margin="0 10 0 0">
                                            <Button Content="Export history to CSV" Width="170" Margin="0 0 8 0" Click="ExportHistoryCsv_Click"/>
                                            <Button Content="Clear history" Width="120" Click="ClearHistory_Click"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Separator Grid.Row="2" Grid.ColumnSpan="3" Margin="0 12 0 12"/>

                                    <StackPanel Grid.Row="3" Grid.ColumnSpan="3">
                                        <TextBlock Text="Diagnostics" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Margin="0 6 0 0">
                                            <TextBlock Text="Log level" VerticalAlignment="Center" Width="220"/>
                                            <ComboBox x:Name="LogLevelBox" Height="28" SelectedIndex="1" Width="220">
                                                <ComboBoxItem Content="Error"/>
                                                <ComboBoxItem Content="Info"/>
                                                <ComboBoxItem Content="Debug"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>


                        </StackPanel>
                    </ScrollViewer>

                    
                    
                    

                    <!-- Footer actions -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 10 0 0">
                        <Button Content="Reset" Width="110" Margin="0 0 8 0" Click="ResetSettings_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Bottom log/output -->
        <Border Grid.Column="2" Grid.Row="2" CornerRadius="10" BorderBrush="#333" BorderThickness="1" Padding="10" Margin="0,4,0,0" Grid.RowSpan="2">
            <TextBox x:Name="OutputBox" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     AcceptsReturn="True" IsReadOnly="True"/>
        </Border>
    </Grid>
</Window>
